# -----------------------------------------------------------------------------
# Configurações do Banco de Dados (Prisma)
# -----------------------------------------------------------------------------
# URL de runtime. Em serverless, prefira Session Pooler ou URL normalizada pelo adapter.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL direta do banco. Usada para migrate deploy/DDL e como fallback do Prisma adapter.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Opcional: limite de conexões do pg Pool usado pelo Prisma adapter.
PRISMA_POOL_MAX="3"

# -----------------------------------------------------------------------------
# Configurações do Supabase (Autenticação / Cliente)
# -----------------------------------------------------------------------------
# Encontre esses valores em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Segredo exigido por rotas administrativas internas, se habilitadas.
ADMIN_SECRET_KEY="troque-este-valor"
