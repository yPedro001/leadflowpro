generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════
// Enums de Controle Administrativo (gestaleadflow-pro)
// ═══════════════════════════════════════════════════════════

enum UserPlan {
  STARTER
  PROFISSIONAL
  ENTERPRISE
}

enum AccessStatus {
  ATIVO
  PAUSADO
  SUSPENSO
  CANCELADO
  AGUARDANDO_PAGAMENTO
  EM_TESTE
}

enum PaymentStatus {
  PAGO
  PENDENTE
  VENCIDO
  EM_TESTE
  ISENTO
  CANCELADO
}

enum UserRole {
  USER
  SUPER_ADMIN
}

// ═══════════════════════════════════════════════════════════
// Profile — estendido com campos de plano e controle de acesso
// ═══════════════════════════════════════════════════════════

model Profile {
  id               String        @id @default(dbgenerated("gen_random_uuid()::text"))
  authUid          String        @unique @map("auth_uid")
  name             String
  email            String        @unique
  role             UserRole      @default(USER)
  plan             UserPlan      @default(STARTER)
  accessStatus     AccessStatus  @default(EM_TESTE) @map("access_status")
  paymentStatus    PaymentStatus @default(EM_TESTE) @map("payment_status")
  monthlyAmount    Decimal?      @map("monthly_amount") @db.Decimal(10, 2)
  paymentMethod    String?       @map("payment_method")
  expiresAt        DateTime?     @map("expires_at")
  lastPaymentAt    DateTime?     @map("last_payment_at")
  nextBillingAt    DateTime?     @map("next_billing_at")
  internalNotes    String?       @map("internal_notes")
  suspensionReason String?       @map("suspension_reason")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  leads            Lead[]
  templates        Template[]
  operators        Operator[]
  cadences         CadenceEngine[]
  notifications    Notification[]
  scheduledActions LeadScheduledAction[]
  billingRecords   BillingRecord[]
  supportTickets   SupportTicket[]

  @@map("profiles")
}

model Lead {
  id             String     @id @default(uuid())
  profileId      String     @map("profile_id")
  code           String     @unique @default(cuid())
  fullName       String     @map("full_name")
  company        String?
  jobTitle       String?    @map("job_title")
  email          String?
  phone          String?
  linkedinUrl    String?    @map("linkedin_url")
  whatsappUrl    String?    @map("whatsapp_url")
  status         LeadStatus @default(NOVO)
  source         LeadSource @default(MANUAL)
  notes          String?
  importBatchId  String?    @map("import_batch_id")
  customSource   String?    @map("custom_source")
  lastOperatorId String?    @map("last_operator_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile          Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lastOperator     Operator?             @relation(fields: [lastOperatorId], references: [id], onDelete: SetNull)
  histories        LeadHistory[]
  leadNotes        LeadNote[]
  scheduledActions LeadScheduledAction[]

  // Nova relação de Cadência
  cadenceEngine LeadCadenceProgress?

  @@index([profileId])
  @@index([lastOperatorId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([profileId, updatedAt(sort: Desc)], map: "idx_leads_profile_updated_at")
  @@index([profileId, status, updatedAt(sort: Desc)], map: "idx_leads_profile_status_updated_at")
  @@index([profileId, source], map: "idx_leads_profile_source")
  @@index([profileId, fullName], map: "idx_leads_profile_full_name")
  @@index([profileId, email], map: "idx_leads_profile_email")
  @@index([profileId, linkedinUrl], map: "idx_leads_profile_linkedin")
  @@map("leads")
}

model CadenceEngine {
  id          String         @id @default(uuid())
  profileId   String?        @map("profile_id")
  name        String
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  profile      Profile?       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  stages       CadenceStage[]
  progressions LeadCadenceProgress[]

  @@index([profileId])
  @@map("cadences")
}

model CadenceStage {
  id         String          @id @default(uuid())
  cadenceId  String          @map("cadence_id")
  order      Int
  channel    TemplateChannel
  delayDays  Int             @map("delay_days")
  templateId String?         @map("template_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  cadence  CadenceEngine @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  template Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([cadenceId])
  @@index([templateId])
  @@map("cadence_stages")
}

model LeadCadenceProgress {
  id                String        @id @default(uuid())
  profileId         String        @map("profile_id")
  leadId            String        @unique @map("lead_id")
  cadenceId         String        @map("cadence_id")
  currentStageOrder Int           @default(1) @map("current_stage_order")
  nextStageOrder    Int?          @map("next_stage_order")
  status            CadenceStatus @default(ACTIVE)
  pausedAt          DateTime?     @map("paused_at")
  finishedAt        DateTime?     @map("finished_at")
  exitReason        String?       @map("exit_reason")
  nextScheduledAt   DateTime      @map("next_scheduled_at")
  lastActionAt      DateTime      @default(now()) @map("last_action_at")
  version           Int           @default(0)
  lockedAt          DateTime?     @map("locked_at")
  lockedBy          String?       @map("locked_by")

  lead    Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  cadence CadenceEngine @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  events  LeadCadenceEvent[]

  @@index([profileId, status, nextScheduledAt])
  @@index([leadId])
  @@index([profileId, status, currentStageOrder, nextScheduledAt, version], map: "idx_lead_cadence_stage_queue")
  @@index([cadenceId, status], map: "idx_lead_cadence_cadence_status")
  @@map("lead_cadence_progress")
}

model LeadCadenceEvent {
  id                    String   @id @default(uuid())
  leadCadenceProgressId String   @map("lead_cadence_id")
  leadId                String   @map("lead_id")
  action                String
  fromStage             Int?     @map("from_stage")
  toStage               Int?     @map("to_stage")
  operatorId            String?  @map("operator_id")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")

  progression LeadCadenceProgress @relation(fields: [leadCadenceProgressId], references: [id], onDelete: Cascade)

  @@index([leadCadenceProgressId])
  @@index([leadId])
  @@map("lead_cadence_events")
}

model Template {
  id        String          @id @default(uuid())
  profileId String          @map("profile_id")
  name      String
  channel   TemplateChannel
  subject   String?
  body      String
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cadenceStages CadenceStage[]

  @@index([profileId])
  @@index([channel])
  @@index([profileId, channel], map: "idx_templates_profile_channel")
  @@map("templates")
}

model LeadHistory {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  previousData Json     @map("previous_data")
  newData      Json     @map("new_data")
  actionBy     String?  @map("action_by")
  createdAt    DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_histories")
}

enum LeadStatus {
  NOVO
  AGUARDANDO_CONEXAO
  AGUARDANDO_RETORNO
  CONTATADO
  EM_NEGOCIACAO
  CONVERTIDO
  PERDIDO
  PAUSADO
}

enum LeadSource {
  MANUAL
  IMPORTACAO_CSV
  IMPORTACAO_XLSX
}

enum TemplateChannel {
  EMAIL
  LINKEDIN
  WHATSAPP
}

enum CadenceStatus {
  ACTIVE
  PAUSED
  FINISHED
  CANCELED
  REPLIED
}

model Operator {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile                Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  leads                  Lead[]
  leadNotes              LeadNote[]
  createdManualActions   LeadScheduledAction[] @relation("ManualActionCreatedBy")
  completedManualActions LeadScheduledAction[] @relation("ManualActionCompletedBy")

  @@index([profileId])
  @@index([profileId, isActive, createdAt(sort: Desc)], map: "idx_operators_profile_active_created")
  @@map("operators")
}

model LeadNote {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  operatorId String?  @map("operator_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  operator Operator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([operatorId])
  @@map("lead_notes")
}

model Notification {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  leadId    String?  @map("lead_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @default("CADENCE_OVERDUE")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([isRead])
  @@index([profileId, isRead, createdAt(sort: Desc)], map: "idx_notifications_profile_read_created")
  @@index([profileId, leadId, type, isRead], map: "idx_notifications_overdue_lookup")
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════
// Ações Manuais Agendadas — independentes da cadência automática
// ═══════════════════════════════════════════════════════════

model LeadScheduledAction {
  id                    String               @id @default(uuid())
  profileId             String               @map("profile_id")
  leadId                String               @map("lead_id")
  title                 String
  actionType            ManualActionType     @default(TAREFA) @map("action_type")
  channel               ManualActionChannel? @map("channel")
  notes                 String?
  scheduledAt           DateTime             @map("scheduled_at")
  status                ManualActionStatus   @default(PENDING)
  createdByOperatorId   String?              @map("created_by_operator_id")
  completedByOperatorId String?              @map("completed_by_operator_id")
  completedAt           DateTime?            @map("completed_at")
  completionNotes       String?              @map("completion_notes")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  profile               Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdByOperator     Operator? @relation("ManualActionCreatedBy", fields: [createdByOperatorId], references: [id], onDelete: SetNull)
  completedByOperator   Operator? @relation("ManualActionCompletedBy", fields: [completedByOperatorId], references: [id], onDelete: SetNull)

  @@index([profileId, status, scheduledAt])
  @@index([leadId])
  @@index([createdByOperatorId])
  @@index([profileId, status, createdByOperatorId, scheduledAt], map: "idx_manual_actions_operator_queue")
  @@map("lead_scheduled_actions")
}

enum ManualActionType {
  LIGACAO
  REUNIAO
  EMAIL
  WHATSAPP
  LINKEDIN
  TAREFA
}

enum ManualActionChannel {
  EMAIL
  LINKEDIN
  WHATSAPP
  TELEFONE
  PRESENCIAL
  OUTRO
}

enum ManualActionStatus {
  PENDING
  DONE
  CANCELED
  MISSED
}

// ═══════════════════════════════════════════════════════════
// BillingRecord — Histórico de pagamentos manuais
// ═══════════════════════════════════════════════════════════

model BillingRecord {
  id            String        @id @default(uuid())
  profileId     String        @map("profile_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @map("payment_status")
  paymentMethod String?       @map("payment_method")
  referenceMonth String?      @map("reference_month")
  paidAt        DateTime?     @map("paid_at")
  dueAt         DateTime?     @map("due_at")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([paymentStatus])
  @@index([profileId, createdAt(sort: Desc)], map: "idx_billing_profile_created")
  @@map("billing_records")
}

// ═══════════════════════════════════════════════════════════
// AdminAuditLog — Log de ações administrativas
// ═══════════════════════════════════════════════════════════

model AdminAuditLog {
  id             String   @id @default(uuid())
  adminEmail     String   @map("admin_email")
  targetProfileId String? @map("target_profile_id")
  targetEmail    String?  @map("target_email")
  action         String
  previousData   Json?    @map("previous_data")
  newData        Json?    @map("new_data")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([adminEmail])
  @@index([targetProfileId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ═══════════════════════════════════════════════════════════
// Suporte Técnico (SaaS)
// ═══════════════════════════════════════════════════════════

enum TicketCategory {
  ACESSO
  ERRO
  DUVIDA
  FINANCEIRO
  SUGESTAO
  OUTRO
}

enum TicketStatus {
  ABERTO
  ATENDIMENTO
  RESPONDIDO
  AGUARDANDO_CLIENTE
  RESOLVIDO
  FECHADO
}

enum TicketPriority {
  BAIXA
  NORMAL
  ALTA
}

enum MessageSenderType {
  CUSTOMER
  ADMIN
}

model SupportTicket {
  id              String         @id @default(uuid())
  profileId       String         @map("profile_id")
  category        TicketCategory
  title           String
  description     String         @db.Text
  status          TicketStatus   @default(ABERTO)
  priority        TicketPriority @default(NORMAL)
  
  isReadByAdmin   Boolean        @default(false) @map("is_read_by_admin")
  isReadByCustomer Boolean       @default(true) @map("is_read_by_customer")

  lastMessageAt   DateTime       @default(now()) @map("last_message_at")
  closedAt        DateTime?      @map("closed_at")
  
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  profile         Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages        SupportTicketMessage[]

  @@index([profileId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id              String            @id @default(uuid())
  ticketId        String            @map("ticket_id")
  senderType      MessageSenderType @map("sender_type")
  senderProfileId String?           @map("sender_profile_id")
  message         String            @db.Text
  isInternalNote  Boolean           @default(false) @map("is_internal_note")
  
  createdAt       DateTime          @default(now()) @map("created_at")

  ticket          SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_ticket_messages")
}
